<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FitnessActivityApp.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Stare aktivnosti">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="18">

        <Label
            Grid.Row="0"
            Text="Stare aktivnosti"
            FontSize="28"
            FontAttributes="Bold" />

        <Label
            Grid.Row="1"
            Text="{Binding EmptyText}"
            FontSize="15"
            TextColor="Gray" />

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Sessions}"
            SelectionMode="Single"
            SelectionChanged="OnSessionSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        StrokeThickness="1"
                        Stroke="#DDDDDD"
                        Padding="16"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 16">

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="{Binding Title}"
                                FontSize="18"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding Summary}"
                                FontSize="14"
                                TextColor="Gray" />
                        </VerticalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>